# ========================================
# LLM Configuration
# ========================================

# OpenAI API Key (required for natural language parsing)
OPENAI_API_KEY=sk-your-openai-key-here


# ========================================
# MCP Server Connection
# ========================================

# Transport type: "auto" (default), "stdio", "http", or "sse"
# - auto: Detects from URL/path (recommended)
# - stdio: Local Python script via subprocess
# - http: Remote server via Streamable HTTP (production)
# - sse: Remote server via SSE (legacy)
NOTION_MCP_TRANSPORT=auto

# --- Option 1: Local Development (STDIO) ---
# Path to your FastMCP Notion server script
NOTION_MCP_PATH=/Users/kas/Projects/kas-fastmcp/main.py

# --- Option 2: Remote Server (HTTP/SSE) ---
# Remote MCP server URL
# NOTION_MCP_URL=https://your-server.fastmcp.cloud/mcp

# Bearer token for authenticated remote servers
# NOTION_MCP_TOKEN=your-bearer-token-here


# ========================================
# Telegram Bot Configuration
# ========================================

# Bot token from @BotFather (required for Telegram interface)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Comma-separated list of allowed Telegram user IDs (optional)
# Leave empty to allow all users (not recommended for production)
# Get your user ID by messaging @userinfobot on Telegram
TELEGRAM_ALLOWED_USERS=123456789,987654321

# Your Telegram DM chat ID for proactive check-ins (same as your user ID)
# Leave unset to disable scheduled messages
# TELEGRAM_CHAT_ID=123456789

# Scheduled check-in times (24h, in TZ below)
# MORNING_CHECKIN_HOUR=8
# EVENING_CHECKIN_HOUR=21
# TZ=America/New_York


# ========================================
# Configuration Priority
# ========================================
# 
# The client uses this priority:
# 1. Explicit parameters passed to NotionMCPClient()
# 2. Environment variables (NOTION_MCP_URL, NOTION_MCP_PATH, etc.)
# 3. Default local path detection
#
# For remote servers:
#   - Set NOTION_MCP_URL and optionally NOTION_MCP_TOKEN
#   - Leave NOTION_MCP_PATH unset or empty
#
# For local development:
#   - Set NOTION_MCP_PATH to your main.py
#   - Leave NOTION_MCP_URL unset or empty
